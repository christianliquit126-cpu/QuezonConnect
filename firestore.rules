rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────

    // Is the user authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Is the user an admin (by Firestore role field)?
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Is the user not banned?
    function notBanned() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'banned';
    }

    // Does the user own the document (by uid field)?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users collection ──────────────────────────────────────────
    // Authenticated users can read any profile (needed for names/avatars)
    // Users manage their own doc; admins can manage any
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Posts collection ──────────────────────────────────────────
    // Public read so the community feed works for everyone
    // Only authenticated non-banned users can create
    // Only post owner or admin can edit/delete
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid;
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin());
      allow delete: if isOwner(resource.data.uid) || isAdmin();

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid;
        allow update: if notBanned() && isOwner(resource.data.uid);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Help Requests collection ──────────────────────────────────
    // Public read so anyone can see requests on the map / feed
    // Only authenticated non-banned users can create
    // Only owner or admin can update/delete
    match /helpRequests/{requestId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid;
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin());
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ── Community Updates (admin-only write) ──────────────────────
    match /communityUpdates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Chats ─────────────────────────────────────────────────────
    // Only participants can read their chat; admin can read all
    match /chats/{chatId} {
      allow read: if isAuth() && (
        resource.data.participants.hasAny([request.auth.uid]) || isAdmin()
      );
      allow create: if isAuth() && notBanned()
        && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isAuth()
        && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isAdmin();

      // Messages: only participants can read/write; owner or admin can delete
      match /messages/{messageId} {
        allow read: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId))
            .data.participants.hasAny([request.auth.uid]);
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/chats/$(chatId))
              .data.participants.hasAny([request.auth.uid]);
        allow update: if isOwner(resource.data.uid);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Notifications ─────────────────────────────────────────────
    // Users can only read their own notifications; system/functions create them
    match /notifications/{notifId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && notBanned();
      allow update: if isAuth() && isOwner(resource.data.userId);
      allow delete: if isAuth() && (isOwner(resource.data.userId) || isAdmin());
    }

    // ── Reports ───────────────────────────────────────────────────
    // Anyone authenticated can submit a report; only admins can read/manage
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && notBanned();
      allow update, delete: if isAdmin();
    }

    // ── Volunteers ────────────────────────────────────────────────
    match /volunteers/{volId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
  }
}
