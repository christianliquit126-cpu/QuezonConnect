rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function notBanned() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'banned';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users collection ──────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Posts collection ──────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid;
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin());
      allow delete: if isOwner(resource.data.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid;
        allow update: if notBanned() && isOwner(resource.data.uid);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Help Requests collection ──────────────────────────────────
    match /helpRequests/{requestId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid;
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin());
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ── Community Updates (admin-only write) ──────────────────────
    match /communityUpdates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Resources (public read, admin write) ─────────────────────
    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Chats ─────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && (
        resource.data.participants.hasAny([request.auth.uid]) || isAdmin()
      );
      allow create: if isAuth() && notBanned()
        && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isAuth()
        && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId))
            .data.participants.hasAny([request.auth.uid]);
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/chats/$(chatId))
              .data.participants.hasAny([request.auth.uid]);
        allow update: if isOwner(resource.data.uid);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Notifications ─────────────────────────────────────────────
    // recipientUid is the field used when creating notifications
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientUid == request.auth.uid;
      allow create: if isAuth() && notBanned();
      allow update: if isAuth() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isAuth() && (resource.data.recipientUid == request.auth.uid || isAdmin());
    }

    // ── Reports ───────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && notBanned();
      allow update, delete: if isAdmin();
    }

    // ── Volunteers ────────────────────────────────────────────────
    match /volunteers/{volId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
  }
}
