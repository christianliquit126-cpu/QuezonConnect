rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function notBanned() {
      return isAuth() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'banned'
      );
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users collection ──────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        // Allow 'user', 'member', or 'admin' on initial create
        // 'admin' is only meaningful when set server-side or via ADMIN_UID env var
        && (!('role' in request.resource.data) || request.resource.data.role in ['user', 'member', 'admin']);
      allow update: if (isOwner(userId) && !affectsRole()) || isAdmin();
      allow delete: if isAdmin();
    }

    // Prevent ordinary users from changing their own role field
    function affectsRole() {
      return 'role' in request.resource.data
        && request.resource.data.role != resource.data.role;
    }

    // ── Posts collection ──────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.content.size() <= 1000;
      // Prevent uid field from being changed on update
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin())
        && (!('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid);
      allow delete: if isOwner(resource.data.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.content.size() <= 500;
        // Owner can edit their own comment; admin can edit any
        allow update: if notBanned() && (isOwner(resource.data.uid) || isAdmin())
          && (!('content' in request.resource.data) || request.resource.data.content.size() <= 500);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Help Requests collection ──────────────────────────────────
    match /helpRequests/{requestId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.title.size() <= 100
        && request.resource.data.description.size() <= 2000
        // Optional phone field: max 20 chars
        && (!('phone' in request.resource.data) || request.resource.data.phone.size() <= 20)
        // Optional neededBy field: max 30 chars
        && (!('neededBy' in request.resource.data) || request.resource.data.neededBy.size() <= 30)
        // Optional location field: max 200 chars
        && (!('location' in request.resource.data) || request.resource.data.location.size() <= 200);
      // Owner/admin can update any field (except uid)
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin())
        && (!('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid);
      // Any authenticated non-banned user can toggle alsoNeedBy votes
      allow update: if isAuth() && notBanned()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['alsoNeedBy', 'alsoNeedCount']);
      // Any authenticated non-banned volunteer can mark helpedBy
      allow update: if isAuth() && notBanned()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpedBy']);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ── Community Updates (admin-only write) ──────────────────────
    match /communityUpdates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Resources (public read, admin write, user helpful-vote) ──
    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
      // Allow authenticated users to vote helpful (only helpfulVotes + helpfulVotedBy fields)
      allow update: if isAuth() && notBanned()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpfulVotes', 'helpfulVotedBy']);
    }

    // ── Chats ─────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && (
        resource.data.participants.hasAny([request.auth.uid]) || isAdmin()
      );
      allow create: if isAuth() && notBanned()
        && request.resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.participants.size() == 2;
      // Participants may only update safe metadata fields, not the participants list itself
      allow update: if isAuth()
        && resource.data.participants.hasAny([request.auth.uid])
        && !('participants' in request.resource.data
              && request.resource.data.participants != resource.data.participants);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId))
            .data.participants.hasAny([request.auth.uid]);
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.content.size() <= 2000
          && get(/databases/$(database)/documents/chats/$(chatId))
              .data.participants.hasAny([request.auth.uid]);
        allow update: if isOwner(resource.data.uid);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Notifications ─────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientUid == request.auth.uid;
      // Sender must be authenticated; cannot impersonate another sender
      allow create: if isAuth() && notBanned()
        && (!('senderUid' in request.resource.data)
            || request.resource.data.senderUid == request.auth.uid);
      // Allow admins to create system-wide broadcast notifications (no senderUid check)
      allow create: if isAdmin();
      allow update: if isAuth() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isAuth()
        && (resource.data.recipientUid == request.auth.uid || isAdmin());
    }

    // ── Reports ───────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && notBanned()
        && request.resource.data.reportedByUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Public stats cache (aggregate counters, admin-write only) ──
    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Volunteers ────────────────────────────────────────────────
    // Document ID must match the authenticated user's UID
    match /volunteers/{volId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && volId == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        // Optional note field: max 200 chars
        && (!('note' in request.resource.data) || request.resource.data.note.size() <= 200);
      // Non-admin volunteers must not be banned to update their own doc;
      // prevent uid field from being changed on update
      allow update: if ((isOwner(resource.data.uid) && volId == request.auth.uid && notBanned())
        || isAdmin())
        && (!('uid' in request.resource.data)
            || request.resource.data.uid == resource.data.uid)
        // Enforce note size limit on updates too
        && (!('note' in request.resource.data) || request.resource.data.note.size() <= 200);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
  }
}
