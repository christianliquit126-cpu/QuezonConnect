rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function notBanned() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'banned';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users collection ──────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        // Prevent role escalation on create — only allow 'user' role on self-create
        && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId) && !affectsRole()) || isAdmin();
      allow delete: if isAdmin();
    }

    // Prevent ordinary users from changing their own role field
    function affectsRole() {
      return 'role' in request.resource.data
        && request.resource.data.role != resource.data.role;
    }

    // ── Posts collection ──────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.content.size() <= 1000;
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin());
      allow delete: if isOwner(resource.data.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.content.size() <= 300;
        allow update: if notBanned() && isOwner(resource.data.uid);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Help Requests collection ──────────────────────────────────
    match /helpRequests/{requestId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.description.size() <= 2000;
      allow update: if notBanned()
        && (isOwner(resource.data.uid) || isAdmin());
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ── Community Updates (admin-only write) ──────────────────────
    match /communityUpdates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Resources (public read, admin write) ─────────────────────
    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Chats ─────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && (
        resource.data.participants.hasAny([request.auth.uid]) || isAdmin()
      );
      allow create: if isAuth() && notBanned()
        && request.resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.participants.size() == 2;
      allow update: if isAuth()
        && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId))
            .data.participants.hasAny([request.auth.uid]);
        allow create: if isAuth() && notBanned()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.content.size() <= 2000
          && get(/databases/$(database)/documents/chats/$(chatId))
              .data.participants.hasAny([request.auth.uid]);
        allow update: if isOwner(resource.data.uid);
        allow delete: if isOwner(resource.data.uid) || isAdmin();
      }
    }

    // ── Notifications ─────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientUid == request.auth.uid;
      // Sender must be authenticated; cannot impersonate another sender
      allow create: if isAuth() && notBanned()
        && (!('senderUid' in request.resource.data)
            || request.resource.data.senderUid == request.auth.uid);
      allow update: if isAuth() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isAuth()
        && (resource.data.recipientUid == request.auth.uid || isAdmin());
    }

    // ── Reports ───────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && notBanned()
        && request.resource.data.reportedByUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Volunteers ────────────────────────────────────────────────
    // Document ID must match the authenticated user's UID
    match /volunteers/{volId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && volId == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow update: if (isOwner(resource.data.uid) && volId == request.auth.uid)
        || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
  }
}
